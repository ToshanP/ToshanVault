<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ToshanVault_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,16">
        <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />

            <!-- Change Master Password -->
            <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Change master password" />
                <PasswordBox x:Name="CurrentPasswordBox" Header="Current password" PlaceholderText="Enter current password" />
                <PasswordBox x:Name="NewPasswordBox" Header="New password" PlaceholderText="Enter new password" />
                <PasswordBox x:Name="ConfirmPasswordBox" Header="Confirm new password" PlaceholderText="Re-enter new password" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="ChangePasswordBtn" Content="Change password"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="ChangePassword_Click" />
                    <ProgressRing x:Name="PasswordProgress" IsActive="False" Width="20" Height="20" Visibility="Collapsed" />
                </StackPanel>
                <InfoBar x:Name="PasswordInfoBar" IsOpen="False" IsClosable="True" />
            </StackPanel>

            <!-- Backup Settings -->
            <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Backup" />
                <ToggleSwitch x:Name="BackupOnExitToggle"
                              Header="Automatically backup database on exit"
                              Toggled="BackupOnExit_Toggled" />
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="When enabled, a copy of vault.db is saved to the backups folder each time you close the app." />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
