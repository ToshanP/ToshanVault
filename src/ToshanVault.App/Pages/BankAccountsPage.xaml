<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.BankAccountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Banking" />
            <Button Grid.Column="1" Content="+ Add account" Click="AddAccount_Click"
                    Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <AutoSuggestBox x:Name="SearchBox" Grid.Row="1"
                        PlaceholderText="Search by bank or account name…"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged" />

        <InfoBar x:Name="InfoBar" Grid.Row="2" IsClosable="True" IsOpen="False" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <GridView x:Name="OpenList" SelectionMode="None"
                          IsItemClickEnabled="False"
                          CanReorderItems="True" CanDragItems="True" AllowDrop="True"
                          DragItemsCompleted="OpenList_DragItemsCompleted">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="12" Width="260" Height="150">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="2">
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Bank}" />
                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding AccountName}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Spacing="2">
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords">
                                            <Run Text="{Binding AccountType}" /><LineBreak />
                                            Acct <Run Text="{Binding MaskedAccountNumber}" />
                                        </TextBlock>
                                        <HyperlinkButton Click="LaunchWebsite_Click" Tag="{Binding Website}"
                                                         Padding="0" Margin="0" MinHeight="0" MinWidth="0"
                                                         Visibility="{Binding WebsiteVisibility}">
                                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Website}" />
                                        </HyperlinkButton>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Click="Edit_Click" Tag="{Binding Id}"
                                                ToolTipService.ToolTip="Edit account details"
                                                Width="32" Height="32" Padding="0">
                                            <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                        </Button>
                                        <Button Click="Notes_Click" Tag="{Binding Id}"
                                                ToolTipService.ToolTip="Notes"
                                                Width="32" Height="32" Padding="0">
                                            <FontIcon Glyph="&#xE70B;" FontSize="14" />
                                        </Button>
                                        <ItemsControl ItemsSource="{Binding Credentials}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="Credential_Click" Tag="{Binding}"
                                                            ToolTipService.ToolTip="{Binding Owner}"
                                                            Width="32" Height="32" Padding="0"
                                                            CornerRadius="16">
                                                        <TextBlock Text="{Binding Initial}"
                                                                   FontWeight="SemiBold" FontSize="14" />
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Click="AddCredential_Click" Tag="{Binding Id}"
                                                ToolTipService.ToolTip="Add login for another owner"
                                                Width="32" Height="32" Padding="0"
                                                Visibility="{Binding CanAddCredentialVisibility}">
                                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                                        </Button>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <Expander x:Name="ClosedExpander" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch" Visibility="Collapsed">
                    <Expander.Header>
                        <TextBlock x:Name="ClosedHeader" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Text="Closed accounts" />
                    </Expander.Header>
                    <GridView x:Name="ClosedList" SelectionMode="None"
                              IsItemClickEnabled="False"
                              CanReorderItems="True" CanDragItems="True" AllowDrop="True"
                              DragItemsCompleted="ClosedList_DragItemsCompleted"
                              Foreground="{ThemeResource TextFillColorDisabledBrush}">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,8,8" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Width="260" Height="150" Opacity="0.7">
                                    <Grid RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Spacing="2">
                                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Bank}" />
                                            <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding AccountName}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextBlockStyle}"
                                                   TextWrapping="WrapWholeWords">
                                            Closed <Run Text="{Binding ClosedDateDisplay}" /><LineBreak />
                                            <Run Text="{Binding ReasonDisplay}" />
                                        </TextBlock>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                                            <Button Click="Edit_Click" Tag="{Binding Id}"
                                                    ToolTipService.ToolTip="Edit / reopen"
                                                    Width="32" Height="32" Padding="0">
                                                <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                            </Button>
                                            <Button Click="Notes_Click" Tag="{Binding Id}"
                                                    ToolTipService.ToolTip="Notes"
                                                    Width="32" Height="32" Padding="0">
                                                <FontIcon Glyph="&#xE70B;" FontSize="14" />
                                            </Button>
                                            <ItemsControl ItemsSource="{Binding Credentials}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="Credential_Click" Tag="{Binding}"
                                                                ToolTipService.ToolTip="{Binding Owner}"
                                                                Width="32" Height="32" Padding="0"
                                                                CornerRadius="16">
                                                            <TextBlock Text="{Binding Initial}"
                                                                       FontWeight="SemiBold" FontSize="14" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
