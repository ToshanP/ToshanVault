<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Dashboard" />

            <!-- Top row: 3 KPI tiles -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Weekly Cashflow -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        Tapped="OpenBudget_Tapped">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Weekly Cashflow" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Income" Opacity="0.6" />
                                <TextBlock x:Name="CashIncomeText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Expenses" Opacity="0.6" />
                                <TextBlock x:Name="CashExpenseText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#C62828" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Surplus" Opacity="0.6" />
                                <TextBlock x:Name="CashSurplusText" Style="{StaticResource SubtitleTextBlockStyle}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="From Budget tile (52-week)" Opacity="0.5" FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- Gold Holdings -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        Tapped="OpenGold_Tapped">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Gold Holdings" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="GoldGramsText" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock x:Name="GoldValueText" Opacity="0.7" />
                        <TextBlock x:Name="GoldPriceText" Opacity="0.5" FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- Loan Payoff -->
                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16"
                        Tapped="OpenRetirement_Tapped">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="LoanNameText" Text="Loan Payoff" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="LoanProgressText" Style="{StaticResource TitleTextBlockStyle}" />
                        <ProgressBar x:Name="LoanProgressBar" Minimum="0" Maximum="100" Value="0" />
                        <TextBlock x:Name="LoanPayoffText" Opacity="0.7" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Insurance renewals (full width) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16"
                    Tapped="OpenInsurance_Tapped">
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="Insurance renewals — next 5" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="InsuranceEmptyText" HorizontalAlignment="Right" Opacity="0.5" Visibility="Collapsed" Text="No upcoming renewals" />
                    </Grid>
                    <ItemsRepeater x:Name="InsuranceRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- Counts strip (full width) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Tapped="OpenVault_Tapped">
                        <TextBlock x:Name="CountVault" HorizontalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Vault entries" HorizontalAlignment="Center" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Tapped="OpenBanks_Tapped">
                        <TextBlock x:Name="CountBanks" HorizontalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Bank accounts" HorizontalAlignment="Center" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Tapped="OpenInsurance_Tapped">
                        <TextBlock x:Name="CountInsurance" HorizontalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Insurance" HorizontalAlignment="Center" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center" Tapped="OpenNotes_Tapped">
                        <TextBlock x:Name="CountNotes" HorizontalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Notes" HorizontalAlignment="Center" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Tapped="OpenRecipes_Tapped">
                        <TextBlock x:Name="CountRecipes" HorizontalAlignment="Center" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Recipes" HorizontalAlignment="Center" Opacity="0.6" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Bottom row: Recent notes + Backup -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock Text="Recently updated notes" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Name="NotesEmptyText" HorizontalAlignment="Right" Opacity="0.5" Visibility="Collapsed" Text="No notes yet" />
                        </Grid>
                        <ItemsRepeater x:Name="NotesRepeater">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="6" />
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Database" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <StackPanel>
                            <TextBlock Text="File" Opacity="0.6" />
                            <TextBlock x:Name="DbPathText" TextWrapping="Wrap" FontSize="12" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Size" Opacity="0.6" />
                                <TextBlock x:Name="DbSizeText" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Last backup" Opacity="0.6" />
                                <TextBlock x:Name="LastBackupText" />
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="BackupBtn" Content="Backup now" Click="BackupNow_Click" />
                        <TextBlock x:Name="BackupStatusText" FontSize="11" Opacity="0.7" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="ErrorText" Foreground="#C62828" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</Page>
