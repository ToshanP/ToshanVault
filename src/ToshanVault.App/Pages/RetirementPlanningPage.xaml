<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.RetirementPlanningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dg="using:CommunityToolkit.WinUI.UI.Controls">
    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Mortgage Payoff" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Mortgage payoff + Mint Investment gold projection. Edit loan values then click Recalculate." />
        </StackPanel>

        <InfoBar x:Name="InfoBar" Grid.Row="1" IsClosable="True" IsOpen="False" />

        <!-- HEADER: data entry -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="Loan inputs" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="14" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Loan name" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBox x:Name="LoanNameBox" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Principal (AUD)" Style="{StaticResource CaptionTextBlockStyle}" />
                        <NumberBox x:Name="PrincipalBox" Minimum="0" SmallChange="1000" LargeChange="10000"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Annual interest rate (%)" Style="{StaticResource CaptionTextBlockStyle}" />
                        <NumberBox x:Name="RateBox" Minimum="0" Maximum="25" SmallChange="0.05" LargeChange="0.5"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Original term (years)" Style="{StaticResource CaptionTextBlockStyle}" />
                        <NumberBox x:Name="TermBox" Minimum="1" Maximum="40" SmallChange="1" LargeChange="5"
                                    SpinButtonPlacementMode="Compact" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="Repayment frequency" Style="{StaticResource CaptionTextBlockStyle}" />
                        <ComboBox x:Name="FrequencyBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Weekly" />
                            <ComboBoxItem Content="Fortnightly" />
                            <ComboBoxItem Content="Monthly" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="Minimum repayment / period (AUD)" Style="{StaticResource CaptionTextBlockStyle}" />
                        <NumberBox x:Name="MinimumPaymentBox" Minimum="0" SmallChange="50" LargeChange="500"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Additional payment / period (AUD)" Style="{StaticResource CaptionTextBlockStyle}" />
                        <NumberBox x:Name="ExtraBox" Minimum="0" SmallChange="50" LargeChange="500"
                                    SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3">
                        <TextBlock Text="Loan start date" Style="{StaticResource CaptionTextBlockStyle}" />
                        <CalendarDatePicker x:Name="StartDateBox" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Notes" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBox x:Name="NotesBox" PlaceholderText="Optional" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                        <Button x:Name="ResetButton"       Content="Reset defaults" Click="Reset_Click" />
                        <Button x:Name="RecalculateButton" Content="🔄 Recalculate"  Click="Recalculate_Click" />
                        <Button x:Name="SaveButton"        Content="💾 Save"        Click="Save_Click"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>

        <!-- Result tabs -->
        <TabView Grid.Row="3" x:Name="ResultsTabs"
                 IsAddTabButtonVisible="False" CanDragTabs="False" CanReorderTabs="False"
                 TabWidthMode="SizeToContent" CloseButtonOverlayMode="Auto">
            <TabView.TabItems>
                <!-- SUMMARY -->
                <TabViewItem Header="📊 Summary" IsClosable="False">
                    <ScrollViewer Padding="4,12,4,12">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Scheduled payment" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="ScheduledLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="ScheduledFreqLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Actual payment (with extra)" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="ActualLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="ActualSubLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Payoff date" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="PayoffDateLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="PayoffSubLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Total interest" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="InterestLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="SavingsLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="🥇 Gold final value (at payoff)" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="GoldFinalLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="GoldContribLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="🪙 Net position at payoff" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="NetLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="NetSubLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Text="loan paid + gold balance" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="🎯 Years to debt-free" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="YearsLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock x:Name="YearsSubLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

                <!-- LOAN SCHEDULE -->
                <TabViewItem Header="🏠 Loan Schedule" IsClosable="False">
                    <dg:DataGrid x:Name="YearGrid"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column">
                        <dg:DataGrid.Columns>
                            <dg:DataGridTextColumn Header="Year"           Binding="{Binding YearNumber}"        Width="80" />
                            <dg:DataGridTextColumn Header="Year ending"    Binding="{Binding YearEndText}"       Width="140" />
                            <dg:DataGridTextColumn Header="Interest paid"  Binding="{Binding InterestPaidText}"  Width="160" />
                            <dg:DataGridTextColumn Header="Principal paid" Binding="{Binding PrincipalPaidText}" Width="160" />
                            <dg:DataGridTextColumn Header="Ending balance" Binding="{Binding EndingBalanceText}" Width="*" />
                        </dg:DataGrid.Columns>
                    </dg:DataGrid>
                </TabViewItem>

                <!-- GOLD PROJECTION -->
                <TabViewItem Header="🥇 Gold Projection" IsClosable="False">
                    <dg:DataGrid x:Name="GoldGrid"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column">
                        <dg:DataGrid.Columns>
                            <dg:DataGridTextColumn Header="Year"            Binding="{Binding YearNumber}"        Width="80" />
                            <dg:DataGridTextColumn Header="Year ending"     Binding="{Binding YearEndText}"       Width="140" />
                            <dg:DataGridTextColumn Header="Contributed"     Binding="{Binding ContributedText}"   Width="150" />
                            <dg:DataGridTextColumn Header="Mint cash"       Binding="{Binding MintCashText}"      Width="140" />
                            <dg:DataGridTextColumn Header="Physical oz"     Binding="{Binding PhysicalOuncesText}" Width="130" />
                            <dg:DataGridTextColumn Header="Total value"     Binding="{Binding TotalValueText}"    Width="*" />
                        </dg:DataGrid.Columns>
                    </dg:DataGrid>
                </TabViewItem>

                <!-- COMBINED -->
                <TabViewItem Header="📈 Combined Plan" IsClosable="False">
                    <ScrollViewer>
                        <Border CornerRadius="10" Margin="0,8,0,0">
                            <Border.Background>
                                <SolidColorBrush Color="#0d1f3c" />
                            </Border.Background>
                            <StackPanel Spacing="0">

                                <!-- HEADER (navy → with gold underline) -->
                                <Border Padding="22,18,22,16" BorderThickness="0,0,0,4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1a3a6e" Offset="0" />
                                            <GradientStop Color="#0d2554" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#f5a623" />
                                    </Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="YOUR FINANCIAL ROADMAP" FontSize="22" FontWeight="ExtraBold"
                                                       Foreground="White" />
                                            <TextBlock x:Name="CombinedSubtitle" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="#a8c4f0" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="14,10" MinWidth="200">
                                            <Border.Background>
                                                <SolidColorBrush Color="#f5a623" />
                                            </Border.Background>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🎯 YOUR GOAL" FontWeight="ExtraBold" FontSize="14" CharacterSpacing="50">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="#0d1f3c" />
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                                <TextBlock x:Name="CombinedGoalLine1" FontWeight="ExtraBold" FontSize="18" Margin="0,3,0,0" TextAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="#0d1f3c" />
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                                <TextBlock x:Name="CombinedGoalLine2" FontWeight="SemiBold" FontSize="14" TextAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="#0d1f3c" />
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- SNAPSHOT STRIP -->
                                <Border BorderThickness="0,0,0,3">
                                    <Border.Background>
                                        <SolidColorBrush Color="#162d55" />
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#1e3f7a" />
                                    </Border.BorderBrush>
                                    <Grid Padding="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Padding="14" Spacing="2">
                                            <TextBlock Text="🏠  LOAN" FontSize="13" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="SnapLoanName" FontWeight="ExtraBold" FontSize="16" Foreground="White" />
                                            <TextBlock x:Name="SnapPrincipal" FontSize="15" Foreground="White" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Padding="14" Spacing="2">
                                            <TextBlock Text="💳  REPAYMENT" FontSize="13" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="SnapPayment" FontWeight="ExtraBold" FontSize="16" Foreground="White" />
                                            <TextBlock x:Name="SnapPaymentSub" FontSize="14">
                                                <TextBlock.Foreground><SolidColorBrush Color="#4cd964" /></TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Padding="14" Spacing="2">
                                            <TextBlock Text="🥇  GOLD STREAM" FontSize="13" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="SnapGold" FontWeight="ExtraBold" FontSize="16" Foreground="White" />
                                            <TextBlock x:Name="SnapGoldSub" FontSize="14">
                                                <TextBlock.Foreground><SolidColorBrush Color="#f5a623" /></TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Padding="14" Spacing="2">
                                            <TextBlock Text="💰  INTEREST SAVED" FontSize="13" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="SnapInterest" FontWeight="ExtraBold" FontSize="16" Foreground="White" />
                                            <TextBlock x:Name="SnapInterestSub" FontSize="14">
                                                <TextBlock.Foreground><SolidColorBrush Color="#4cd964" /></TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- TIMELINE -->
                                <StackPanel Padding="22,18,22,8" Spacing="12">
                                    <TextBlock Text="⏱  TIMELINE OVERVIEW" FontWeight="ExtraBold" FontSize="16" HorizontalAlignment="Center" CharacterSpacing="200">
                                        <TextBlock.Foreground><SolidColorBrush Color="#f5a623" /></TextBlock.Foreground>
                                    </TextBlock>
                                    <Grid x:Name="TimelineGrid" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 5 columns populated in code-behind -->
                                    </Grid>
                                </StackPanel>

                                <!-- PHASE CARDS -->
                                <Grid Padding="20,4,20,18" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="10" Padding="14,12" BorderThickness="0,4,0,0">
                                        <Border.Background><SolidColorBrush Color="#162d55" /></Border.Background>
                                        <Border.BorderBrush><SolidColorBrush Color="#4a9af5" /></Border.BorderBrush>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="🏠  LOAN START" FontSize="14" FontWeight="ExtraBold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#4a9af5" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="Phase1Period" FontSize="12" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#d0e0ff">
                                                <Run Text="› Pay base + extra each period" /><LineBreak/>
                                                <Run Text="› Stay disciplined, no extra debt" /><LineBreak/>
                                                <Run Text="› Track progress monthly" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="10" Padding="14,12" BorderThickness="0,4,0,0">
                                        <Border.Background><SolidColorBrush Color="#1a2e1a" /></Border.Background>
                                        <Border.BorderBrush><SolidColorBrush Color="#4cd964" /></Border.BorderBrush>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="🎯  HALFWAY POINT" FontSize="14" FontWeight="ExtraBold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#4cd964" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="Phase2Period" FontSize="12" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#d0e0ff">
                                                <Run Text="› Loan ~50% paid down" /><LineBreak/>
                                                <Run Text="› Momentum building" /><LineBreak/>
                                                <Run Text="› Consider increasing extras" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" CornerRadius="10" Padding="14,12" BorderThickness="0,4,0,0">
                                        <Border.Background><SolidColorBrush Color="#2a1f0e" /></Border.Background>
                                        <Border.BorderBrush><SolidColorBrush Color="#f5a623" /></Border.BorderBrush>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="🥇  GOLD ACCUMULATING" FontSize="14" FontWeight="ExtraBold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#f5a623" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="Phase3Period" FontSize="12" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="Phase3MintLine" TextWrapping="Wrap" FontSize="14" Foreground="#d0e0ff">
                                                <Run Text="› Mint Investment funding" /><LineBreak/>
                                                <Run Text="› Loan + gold growing in parallel" /><LineBreak/>
                                                <Run Text="› Long-term wealth buffer" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="3" CornerRadius="10" Padding="14,12" BorderThickness="0,4,0,0">
                                        <Border.Background><SolidColorBrush Color="#1e1a2e" /></Border.Background>
                                        <Border.BorderBrush><SolidColorBrush Color="#af52de" /></Border.BorderBrush>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="🏖  DEBT-FREE" FontSize="14" FontWeight="ExtraBold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#af52de" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock x:Name="Phase4Period" FontSize="12" FontWeight="Bold">
                                                <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#d0e0ff">
                                                <Run Text="› Loan cleared" /><LineBreak/>
                                                <Run Text="› Gold buffer remaining" /><LineBreak/>
                                                <Run Text="› Enjoy financial freedom" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- PROJECTION TABLE + GOLD SIDEBAR -->
                                <StackPanel Padding="20,4,20,18" Spacing="12">
                                    <TextBlock Text="📊  YEAR-BY-YEAR PROJECTION" FontWeight="ExtraBold" FontSize="16" HorizontalAlignment="Center">
                                        <TextBlock.Foreground><SolidColorBrush Color="#f5a623" /></TextBlock.Foreground>
                                    </TextBlock>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Loan + gold combined table -->
                                        <Border Grid.Column="0" CornerRadius="10">
                                            <Border.Background><SolidColorBrush Color="#0f1e35" /></Border.Background>
                                            <StackPanel>
                                                <Border Padding="12,10">
                                                    <Border.Background><SolidColorBrush Color="#1a3a6e" /></Border.Background>
                                                    <StackPanel>
                                                        <TextBlock Text="LOAN + GOLD COMBINED" FontWeight="ExtraBold" FontSize="14">
                                                            <TextBlock.Foreground><SolidColorBrush Color="#4a9af5" /></TextBlock.Foreground>
                                                        </TextBlock>
                                                        <TextBlock Text="Year-end loan balance and accumulated gold value" FontSize="13">
                                                            <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <dg:DataGrid x:Name="CombinedGrid"
                                                             AutoGenerateColumns="False"
                                                             IsReadOnly="True"
                                                             GridLinesVisibility="Horizontal"
                                                             HeadersVisibility="Column"
                                                             Background="Transparent"
                                                             Foreground="White"
                                                             FontSize="14"
                                                             RowHeight="32"
                                                             RowBackground="Transparent"
                                                             AlternatingRowBackground="#16263d"
                                                             MaxHeight="380">
                                                    <dg:DataGrid.Columns>
                                                        <dg:DataGridTextColumn Header="Year"           Binding="{Binding YearNumber}"      Width="60" />
                                                        <dg:DataGridTextColumn Header="Year ending"    Binding="{Binding YearEndText}"     Width="120" />
                                                        <dg:DataGridTextColumn Header="Loan balance"   Binding="{Binding LoanBalanceText}" Width="140" />
                                                        <dg:DataGridTextColumn Header="Gold value"     Binding="{Binding GoldValueText}"   Width="140" />
                                                        <dg:DataGridTextColumn Header="Net (gold − loan)" Binding="{Binding NetText}"      Width="*" />
                                                    </dg:DataGrid.Columns>
                                                </dg:DataGrid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Gold growth sidebar -->
                                        <Border Grid.Column="1" CornerRadius="10">
                                            <Border.Background><SolidColorBrush Color="#1a1308" /></Border.Background>
                                            <StackPanel>
                                                <Border Padding="12,10" BorderThickness="0,3,0,0">
                                                    <Border.Background><SolidColorBrush Color="#2a1f0e" /></Border.Background>
                                                    <Border.BorderBrush><SolidColorBrush Color="#f5a623" /></Border.BorderBrush>
                                                    <StackPanel>
                                                        <TextBlock Text="💛 GOLD GROWTH" FontWeight="ExtraBold" FontSize="14">
                                                            <TextBlock.Foreground><SolidColorBrush Color="#f5a623" /></TextBlock.Foreground>
                                                        </TextBlock>
                                                        <TextBlock x:Name="GoldSidebarSub" FontSize="12">
                                                            <TextBlock.Foreground><SolidColorBrush Color="#c8a060" /></TextBlock.Foreground>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <ItemsControl x:Name="GoldSidebarRows" Padding="0,4,0,4">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="14,5" BorderThickness="0,0,0,1">
                                                                <Border.BorderBrush><SolidColorBrush Color="#2a1f0e" /></Border.BorderBrush>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding YearLabel}" FontSize="14" FontWeight="SemiBold">
                                                                        <TextBlock.Foreground><SolidColorBrush Color="#a8c4f0" /></TextBlock.Foreground>
                                                                    </TextBlock>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ValueText}" FontWeight="ExtraBold" FontSize="15">
                                                                        <TextBlock.Foreground><SolidColorBrush Color="#f5a623" /></TextBlock.Foreground>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Padding="12,8" BorderThickness="0,1,0,0">
                                                    <Border.BorderBrush><SolidColorBrush Color="#2a1f0e" /></Border.BorderBrush>
                                                    <TextBlock TextWrapping="Wrap" FontSize="13" FontStyle="Italic">
                                                        <TextBlock.Foreground><SolidColorBrush Color="#c8a060" /></TextBlock.Foreground>
                                                        Gold is your "finishing weapon" — a growing buffer alongside the loan, not the main engine.
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <!-- BOTTOM ROW: KEY DATES + RULES -->
                                <Grid Padding="20,4,20,18" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="10">
                                        <Border.Background><SolidColorBrush Color="#0f1e35" /></Border.Background>
                                        <StackPanel>
                                            <Border Padding="14,10">
                                                <Border.Background><SolidColorBrush Color="#1a3a6e" /></Border.Background>
                                                <TextBlock Text="📅  KEY DATES" FontWeight="ExtraBold" FontSize="14">
                                                    <TextBlock.Foreground><SolidColorBrush Color="#4a9af5" /></TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel x:Name="CombinedKeyDatesPanel" Padding="10,8" Spacing="6" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="10">
                                        <Border.Background><SolidColorBrush Color="#1a0f0f" /></Border.Background>
                                        <StackPanel>
                                            <Border Padding="14,10">
                                                <Border.Background><SolidColorBrush Color="#2a1a1a" /></Border.Background>
                                                <TextBlock Text="📋  KEY STRATEGY RULES" FontWeight="ExtraBold" FontSize="14">
                                                    <TextBlock.Foreground><SolidColorBrush Color="#f56565" /></TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel Padding="14,8" Spacing="6">
                                                <TextBlock Text="✅ DO" FontWeight="ExtraBold" FontSize="14">
                                                    <TextBlock.Foreground><SolidColorBrush Color="#4cd964" /></TextBlock.Foreground>
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#d0e0ff">
                                                    <Run Text="✔ Pay extra consistently — every period counts" /><LineBreak/>
                                                    <Run Text="✔ Keep gold contributions automatic" /><LineBreak/>
                                                    <Run Text="✔ Re-run the calculator after rate changes" /><LineBreak/>
                                                    <Run Text="✔ Use offset/redraw to your advantage" />
                                                </TextBlock>
                                                <TextBlock Text="❌ DO NOT" FontWeight="ExtraBold" FontSize="14" Margin="0,6,0,0">
                                                    <TextBlock.Foreground><SolidColorBrush Color="#f56565" /></TextBlock.Foreground>
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#d0e0ff">
                                                    <Run Text="✗ Take on new debt during payoff" /><LineBreak/>
                                                    <Run Text="✗ Sell gold emotionally — wait for the strategic window" /><LineBreak/>
                                                    <Run Text="✗ Skip payments — even 1 month adds years" /><LineBreak/>
                                                    <Run Text="✗ Underestimate the power of compounding" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- FOOTER -->
                                <Border Padding="22,12">
                                    <Border.Background><SolidColorBrush Color="#f5a623" /></Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🏆 DISCIPLINE TODAY = FREEDOM TOMORROW" FontWeight="ExtraBold" FontSize="18">
                                            <TextBlock.Foreground><SolidColorBrush Color="#0d1f3c" /></TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="Estimates only — not licensed financial advice." FontSize="14" FontWeight="SemiBold">
                                            <TextBlock.Foreground><SolidColorBrush Color="#0d1f3c" /></TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabViewItem>

                <!-- KEY DATES -->
                <TabViewItem Header="📅 Key Dates" IsClosable="False">
                    <ScrollViewer Padding="4,12,4,12">
                        <StackPanel x:Name="KeyDatesPanel" Spacing="8" />
                    </ScrollViewer>
                </TabViewItem>
            </TabView.TabItems>
        </TabView>
    </Grid>
</Page>
