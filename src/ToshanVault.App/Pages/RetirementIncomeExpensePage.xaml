<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.RetirementIncomeExpensePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dg="using:CommunityToolkit.WinUI.UI.Controls">
    <ScrollViewer VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <!-- Right-align numeric DataGrid cells and totals so the dollar
                 amounts line up on their decimal points. -->
            <Style x:Key="RightAlignedCell" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="Padding" Value="0,0,12,0" />
            </Style>
        </ScrollViewer.Resources>
        <Grid Padding="24,16,24,24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Retirement Income / Expense" />
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Annual amounts (Jan 2025 baseline). Weekly is calculated as Annual ÷ 52." />
            </StackPanel>

            <InfoBar x:Name="InfoBar" Grid.Row="1" IsClosable="True" IsOpen="False" />

            <!-- ============================ EXPENSES ============================ -->
            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Expenses" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Content="+ Add"     Click="AddExpense_Click"    Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="EditExpenseBtn"   Content="✏ Edit"   Click="EditExpense_Click"   IsEnabled="False" />
                            <Button x:Name="DeleteExpenseBtn" Content="🗑 Delete" Click="DeleteExpense_Click" IsEnabled="False" />
                        </StackPanel>
                    </Grid>

                    <dg:DataGrid x:Name="ExpenseGrid"
                                 AutoGenerateColumns="False"
                                 SelectionMode="Single"
                                 IsReadOnly="True"
                                 CanUserSortColumns="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column"
                                 SelectionChanged="ExpenseGrid_SelectionChanged"
                                 Sorting="ExpenseGrid_Sorting"
                                 DoubleTapped="ExpenseGrid_DoubleTapped"
                                 MaxHeight="520">
                        <dg:DataGrid.Columns>
                            <dg:DataGridTextColumn Header="Description" Tag="Label"  Binding="{Binding Label}"           Width="3*" />
                            <dg:DataGridTextColumn Header="Annual"      Tag="Annual" Binding="{Binding AnnualDisplay}"  Width="*"
                                                   ElementStyle="{StaticResource RightAlignedCell}" />
                            <dg:DataGridTextColumn Header="Weekly"      Tag="Weekly" Binding="{Binding WeeklyDisplay}"  Width="*"
                                                   ElementStyle="{StaticResource RightAlignedCell}" />
                        </dg:DataGrid.Columns>
                    </dg:DataGrid>

                    <Grid x:Name="ExpenseTotalsGrid" Padding="6,2,6,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Total" />
                        <TextBlock Grid.Column="1" x:Name="ExpenseAnnualTotal" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Right" TextAlignment="Right" />
                        <TextBlock Grid.Column="2" x:Name="ExpenseWeeklyTotal" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Right" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============================ INCOME ============================ -->
            <Border Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Income" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Content="+ Add"     Click="AddIncome_Click"    Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="EditIncomeBtn"   Content="✏ Edit"   Click="EditIncome_Click"   IsEnabled="False" />
                            <Button x:Name="DeleteIncomeBtn" Content="🗑 Delete" Click="DeleteIncome_Click" IsEnabled="False" />
                        </StackPanel>
                    </Grid>

                    <dg:DataGrid x:Name="IncomeGrid"
                                 AutoGenerateColumns="False"
                                 SelectionMode="Single"
                                 IsReadOnly="True"
                                 CanUserSortColumns="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column"
                                 SelectionChanged="IncomeGrid_SelectionChanged"
                                 Sorting="IncomeGrid_Sorting"
                                 DoubleTapped="IncomeGrid_DoubleTapped"
                                 MaxHeight="320">
                        <dg:DataGrid.Columns>
                            <dg:DataGridTextColumn Header="Description" Tag="Label"  Binding="{Binding Label}"           Width="3*" />
                            <dg:DataGridTextColumn Header="Annual"      Tag="Annual" Binding="{Binding AnnualDisplay}"  Width="*"
                                                   ElementStyle="{StaticResource RightAlignedCell}" />
                            <dg:DataGridTextColumn Header="Weekly"      Tag="Weekly" Binding="{Binding WeeklyDisplay}"  Width="*"
                                                   ElementStyle="{StaticResource RightAlignedCell}" />
                        </dg:DataGrid.Columns>
                    </dg:DataGrid>

                    <Grid x:Name="IncomeTotalsGrid" Padding="6,2,6,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Total" />
                        <TextBlock Grid.Column="1" x:Name="IncomeAnnualTotal" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Right" TextAlignment="Right" />
                        <TextBlock Grid.Column="2" x:Name="IncomeWeeklyTotal" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Right" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============================ SURPLUS ============================ -->
            <Border Grid.Row="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid x:Name="SurplusGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="0" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SurplusLabel" Style="{StaticResource SubtitleTextBlockStyle}" Text="Surplus (Income − Expense)" />
                    <TextBlock Grid.Column="1" x:Name="SurplusAnnual" Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Right" TextAlignment="Right" />
                    <TextBlock Grid.Column="2" x:Name="SurplusWeekly" Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Right" TextAlignment="Right" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
