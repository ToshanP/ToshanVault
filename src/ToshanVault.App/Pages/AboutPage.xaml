<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ToshanVault_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,16">
        <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="About" />

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="ToshanVault" />
                <TextBlock x:Name="VersionText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock TextWrapping="Wrap"
                       Text="A personal vault desktop app for securely managing family data — bank accounts, insurance, credentials, gold ornaments, recipes, budgets, retirement planning, and general notes." />

            <StackPanel Spacing="4" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Technology" />
                <TextBlock Text="WinUI 3 / .NET 10 / SQLite / AES-256-GCM" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Security" />
                <TextBlock TextWrapping="Wrap"
                           Text="All sensitive data is encrypted at rest using AES-256-GCM with a data encryption key (DEK) that is wrapped by a password-derived key (PBKDF2-SHA256, 200k iterations). The DEK never touches disk in plaintext." />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Data location" />
                <TextBlock x:Name="DataPathText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
