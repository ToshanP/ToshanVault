<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <NavigationView
        x:Name="NavView"
        IsBackButtonVisible="Collapsed"
        IsTitleBarAutoPaddingEnabled="False"
        IsSettingsVisible="True"
        SelectionChanged="NavView_SelectionChanged"
        Loaded="NavView_Loaded">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Search" Tag="search">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE721;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Dashboard" Tag="dashboard" IsSelected="True">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Budget" Tag="budget">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8C7;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Vault" Tag="vault">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE72E;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Insurance" Tag="insurance">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE83D;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Banking" Tag="banks">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8C7;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Notes" Tag="notes">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE70B;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Retirement Cashflow" Tag="retincexp">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE9F9;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Mortgage Payoff" Tag="retirement">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE7BA;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Mint Investment" Tag="mint">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8D7;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Jewellery" Tag="gold">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xEC4F;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Lock" Tag="lock">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE72E;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="About" Tag="about">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xEA3A;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
