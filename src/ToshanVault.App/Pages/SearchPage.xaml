<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ToshanVault_App.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <DataTemplate x:Key="ResultTemplate">
            <Button HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent" BorderThickness="0"
                    Padding="12,8" Margin="0,1"
                    Click="Result_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis" MaxLines="1" />
                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" MaxLines="1" />
                    </StackPanel>
                    <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="12"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              VerticalAlignment="Center" />
                </Grid>
            </Button>
        </DataTemplate>
    </Page.Resources>
    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Search" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Search across Vault, Banking, Insurance and Notes." />
        </StackPanel>

        <AutoSuggestBox x:Name="SearchBox" Grid.Row="1"
                        PlaceholderText="Type to search across all categories…"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged" />

        <InfoBar x:Name="InfoBar" Grid.Row="2" IsClosable="True" IsOpen="False" />

        <ScrollViewer Grid.Row="3">
            <StackPanel Spacing="20">
                <TextBlock x:Name="EmptyPrompt"
                           Text="Start typing to search across Vault, Banking, Insurance and Notes."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0" />

                <TextBlock x:Name="NoResultsText"
                           Text="No results found."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"
                           Visibility="Collapsed" />

                <StackPanel x:Name="VaultSection" Visibility="Collapsed" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE72E;" FontSize="16" />
                        <TextBlock x:Name="VaultHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ItemsControl x:Name="VaultList" ItemTemplate="{StaticResource ResultTemplate}" />
                </StackPanel>

                <StackPanel x:Name="BankingSection" Visibility="Collapsed" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE8C7;" FontSize="16" />
                        <TextBlock x:Name="BankingHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ItemsControl x:Name="BankingList" ItemTemplate="{StaticResource ResultTemplate}" />
                </StackPanel>

                <StackPanel x:Name="InsuranceSection" Visibility="Collapsed" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE83D;" FontSize="16" />
                        <TextBlock x:Name="InsuranceHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ItemsControl x:Name="InsuranceList" ItemTemplate="{StaticResource ResultTemplate}" />
                </StackPanel>

                <StackPanel x:Name="NotesSection" Visibility="Collapsed" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE70B;" FontSize="16" />
                        <TextBlock x:Name="NotesHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <ItemsControl x:Name="NotesList" ItemTemplate="{StaticResource ResultTemplate}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
