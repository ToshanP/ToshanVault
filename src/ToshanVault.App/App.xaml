<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ToshanVault_App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ToshanVault_App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NormalDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="76" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style x:Key="NormalPrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="MinWidth" Value="76" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style TargetType="ContentDialog">
                <Setter Property="PrimaryButtonStyle" Value="{StaticResource NormalPrimaryDialogButtonStyle}" />
                <Setter Property="SecondaryButtonStyle" Value="{StaticResource NormalDialogButtonStyle}" />
                <Setter Property="CloseButtonStyle" Value="{StaticResource NormalDialogButtonStyle}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
